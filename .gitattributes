# Normalize line endings for all text files
* text=auto eol=lf

# Godot scene and resource files — treat as text, never mangle
*.gd        text eol=lf
*.tscn      text eol=lf
*.tres      text eol=lf
*.gdshader  text eol=lf
*.godot     text eol=lf
*.cfg       text eol=lf

# JSON data files
*.json      text eol=lf

# Binary assets — do not diff or mangle
*.png       binary
*.jpg       binary
*.jpeg      binary
*.webp      binary
*.svg       binary
*.ogg       binary
*.wav       binary
*.mp3       binary
*.ttf       binary
*.woff      binary
*.woff2     binary
